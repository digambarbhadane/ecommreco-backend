						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set(\"token\", jsonData.data.accessToken);",
									"    console.log(\"Token saved\");",
									"}",
									"if (jsonData.data && jsonData.data.user && jsonData.data.user.id) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.data.user.id);",
									"    console.log(\"User ID saved: \" + jsonData.data.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
