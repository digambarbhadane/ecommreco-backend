NODE_ENV=test
PORT=5000

FRONTEND_URL=http://localhost:8080
FRONTEND_URLS=http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=true

# MongoDB — use ecommreco_test database (Atlas or local)
MONGODB_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/ecommreco_test?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGODB_DB_NAME=ecommreco_test
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/ecommreco_test
USE_MEMORY_DB=false
ALLOW_MEMORY_DB_FALLBACK=true

JWT_SECRET=test-env-only-change-me-use-long-random-string-32chars-min
SUPER_ADMIN_SETUP_TOKEN=

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

POSTMARK_API_KEY=
EMAIL_AUTH=auth@ecommreco.com
EMAIL_BILLING=billing@ecommreco.com
EMAIL_NOTIFICATION=notifications@ecommreco.com
EMAIL_USE_QUEUE=false

ENABLE_SWAGGER=true

DEV_SUPER_ADMIN_EMAIL=superadmin@test.com
DEV_SUPER_ADMIN_PASSWORD=password123
